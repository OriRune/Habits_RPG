# Supabase project credentials (Phase 1+). Copy this file to `.env.local` and fill in.
# Find these in your Supabase dashboard under Project Settings → API.
# The anon key is a public client key (safe to ship in the browser bundle); never
# put the service_role key here — it must stay server-side only.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
